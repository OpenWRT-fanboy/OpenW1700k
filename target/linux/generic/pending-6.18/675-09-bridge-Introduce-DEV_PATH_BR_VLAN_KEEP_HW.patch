From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
Subject: [PATCH 09/10] bridge: Introduce DEV_PATH_BR_VLAN_KEEP_HW

Add a new DEV_PATH_BR_VLAN_KEEP_HW path type for switchdev-backed
bridge ports where the VLAN should be kept in hardware. This allows
the flow offload path to correctly handle the case where a tagged VLAN
is kept by the switchdev in hardware without software stripping.

Signed-off-by: OpenWrt Build <build@openwrt.org>
---
 include/linux/netdevice.h |  1 +
 net/bridge/br_device.c    |  1 +
 net/bridge/br_vlan.c      |  7 +++++--
 net/netfilter/nft_flow_offload.c |  1 +
 4 files changed, 8 insertions(+), 2 deletions(-)

diff --git a/include/linux/netdevice.h b/include/linux/netdevice.h
index a318ce4..560e6df 100644
--- a/include/linux/netdevice.h
+++ b/include/linux/netdevice.h
@@ -893,6 +893,7 @@ struct net_device_path {
 				DEV_PATH_BR_VLAN_TAG,
 				DEV_PATH_BR_VLAN_UNTAG,
 				DEV_PATH_BR_VLAN_UNTAG_HW,
+				DEV_PATH_BR_VLAN_KEEP_HW,
 			}		vlan_mode;
 			u16		vlan_id;
 			__be16		vlan_proto;
diff --git a/net/bridge/br_device.c b/net/bridge/br_device.c
index 525d4ec..da28125 100644
--- a/net/bridge/br_device.c
+++ b/net/bridge/br_device.c
@@ -423,6 +423,7 @@ static int br_fill_forward_path(struct net_device_path_ctx *ctx,
 	case DEV_PATH_BR_VLAN_UNTAG:
 		ctx->num_vlans--;
 		break;
+	case DEV_PATH_BR_VLAN_KEEP_HW:
 	case DEV_PATH_BR_VLAN_KEEP:
 		break;
 	}
diff --git a/net/bridge/br_vlan.c b/net/bridge/br_vlan.c
index ce9d189..7673fb1 100644
--- a/net/bridge/br_vlan.c
+++ b/net/bridge/br_vlan.c
@@ -1489,9 +1489,12 @@ int br_vlan_fill_forward_path_mode(struct net_bridge *br,
 	if (!(v->flags & BRIDGE_VLAN_INFO_UNTAGGED))
 		return 0;
 
-	if (path->bridge.vlan_mode == DEV_PATH_BR_VLAN_TAG)
-		path->bridge.vlan_mode = DEV_PATH_BR_VLAN_KEEP;
-	else if (v->priv_flags & BR_VLFLAG_ADDED_BY_SWITCHDEV)
+	if (path->bridge.vlan_mode == DEV_PATH_BR_VLAN_TAG) {
+		if (v->priv_flags & BR_VLFLAG_ADDED_BY_SWITCHDEV)
+			path->bridge.vlan_mode = DEV_PATH_BR_VLAN_KEEP_HW;
+		else
+			path->bridge.vlan_mode = DEV_PATH_BR_VLAN_KEEP;
+	} else if (v->priv_flags & BR_VLFLAG_ADDED_BY_SWITCHDEV)
 		path->bridge.vlan_mode = DEV_PATH_BR_VLAN_UNTAG_HW;
 	else
 		path->bridge.vlan_mode = DEV_PATH_BR_VLAN_UNTAG;
diff --git a/net/netfilter/nft_flow_offload.c b/net/netfilter/nft_flow_offload.c
index a09555b..c4da2b5 100644
--- a/net/netfilter/nft_flow_offload.c
+++ b/net/netfilter/nft_flow_offload.c
@@ -221,6 +221,7 @@ static void nft_dev_path_info(const struct net_device_path_stack *stack,
 					break;
 				info->num_encaps--;
 				break;
+			case DEV_PATH_BR_VLAN_KEEP_HW:
 			case DEV_PATH_BR_VLAN_KEEP:
 				break;
 			}
-- 
2.39.0

